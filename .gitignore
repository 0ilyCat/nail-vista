# Build output artifacts (PPT/Report/screenshots — not versioned)
output/
screenshots/
.playwright-cli/

# Backend runtime data
# AI 生成的试戴结果图（运行时产生，不提交）
backend/results/
# 上传计数器（运行时状态）
backend/uploads/.upload_counter

# WorkBuddy
.workbuddy/

# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
.pytest_cache/

# Node
node_modules/
dist/
.vite/

# Env & secrets
.env
*.db

# OS
.DS_Store
Thumbs.db

# ─── OpenClaw 项目内配置 (仅运行时状态忽略，配置文件提交) ───

# 运行时日志
.openclaw/logs/

# 运行时 workspace（agent 工作目录）
.openclaw/workspace/

# 设备身份与配对（私密，每人独有）
.openclaw/identity/
.openclaw/devices/

# Agent 运行时状态
.openclaw/agents/*/state/
.openclaw/agents/*/sessions/
.openclaw/agents/*/.openclaw/

# 自动创建的 Agent 会话目录（含旧 ID 遗留）
.openclaw/agents/nailvista-*/

# 自动创建的 workspace 目录（含旧 ID 遗留，运行时自动生成）
.openclaw/workspace-*/

# Agent 记忆数据库（运行时）
.openclaw/memory/

# 插件安装缓存
.openclaw/plugins/

# 任务调度数据库（运行时）
.openclaw/tasks/

# 配置回滚文件（运行时自动备份，非源文件）
.openclaw/openclaw.json.last-good

# 版本检查缓存
.openclaw/update-check.json

# Temp files
*.log
*.tmp
*~
