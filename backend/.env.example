# NailVista 环境配置模板
# 复制此文件为 .env 并填入你的真实配置
DEBUG=true

# MySQL 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=nail_vista

# JWT
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256

# OpenClaw AI Gateway
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-token

# 阿里云 OSS 对象存储
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your-bucket-name

# 图片访问URL (OSS 公开读)
IMAGE_BASE_URL=https://your-bucket.oss-cn-beijing.aliyuncs.com

# 百炼 AI 模型
DASHSCOPE_API_KEY=your-dashscope-api-key

# CORS
CORS_ORIGINS=["http://localhost:4180","http://localhost:5173","http://localhost:3000"]
