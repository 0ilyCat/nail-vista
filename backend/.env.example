# NailVista environment template
# Copy this file to .env, then choose ONE database option below.

DEBUG=true

# Option A: local zero-install database, recommended for demos and teammates without MySQL.
# The generated .db file is ignored by Git.
# DATABASE_URL=sqlite+aiosqlite:///./nail_vista.db

# Option B: MySQL, keep DATABASE_URL commented and fill these values.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=nail_vista

# Option C: PostgreSQL, useful when running the existing docker-compose.yml.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nail_tryon

# JWT
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256

# OpenClaw AI Gateway
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-token

# Local image storage. Leave empty to use relative /api/getImg?name= paths.
IMAGE_BASE_URL=

# DashScope model key, required only for real AI try-on generation.
DASHSCOPE_API_KEY=your-dashscope-api-key

# CORS
CORS_ORIGINS=["http://localhost:4180","http://localhost:5173","http://localhost:3000"]
