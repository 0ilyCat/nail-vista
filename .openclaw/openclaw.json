{
  "env": {
    "MIMO_API_KEY": "tp-ck77z6dfpe4biuktho9ps97wjo8dpn6fq41rtzcekflz7dbs",
    "OPENCLAW_GATEWAY_TOKEN": "nailvista-dev-token"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "xiaomi-coding": {
        "baseUrl": "https://token-plan-cn.xiaomimimo.com/v1",
        "api": "openai-completions",
        "apiKey": "${MIMO_API_KEY}",
        "models": [
          {
            "id": "mimo-v2.5-pro",
            "name": "MiMo V2.5 Pro",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 1048576,
            "maxTokens": 32000
          },
          {
            "id": "mimo-v2.5",
            "name": "MiMo V2.5",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 262144,
            "maxTokens": 32000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "xiaomi-coding/mimo-v2.5-pro"
      },
      "models": {
        "xiaomi-coding/mimo-v2.5": { "alias": "MiMo V2.5" },
        "xiaomi-coding/mimo-v2.5-pro": { "alias": "MiMo V2.5 Pro" }
      }
    },
    "list": [
      {
        "id": "nailvista-xiaomei",
        "name": "小美",
        "workspace": ".openclaw/workspace/xiaomei",
        "agentDir": ".openclaw/agents/xiaomei/state"
      },
      {
        "id": "nailvista-ops",
        "name": "运营助手",
        "workspace": ".openclaw/workspace/ops",
        "agentDir": ".openclaw/agents/ops/state"
      }
    ]
  },
  "browser": {
    "enabled": true,
    "evaluateEnabled": false,
    "defaultProfile": "user",
    "tabCleanup": {
      "enabled": true,
      "idleMinutes": 30,
      "maxTabsPerSession": 4
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "http": {
      "endpoints": {
        "chatCompletions": { "enabled": true }
      }
    }
  }
}
